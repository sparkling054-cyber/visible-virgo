---

<!doctype html>

<html lang="ja">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
/>

<title>404 Not Found</title>

<style>

html,
body{

margin:0;
width:100%;
height:100%;
overflow:hidden;
background:#000;

}

body{

display:flex;
justify-content:center;
align-items:center;

}

.wrapper{

position:relative;
width:100vw;
height:100vh;

}

.bg{

position:absolute;
inset:0;
width:100%;
height:100%;
object-fit:cover;
user-select:none;
pointer-events:none;

}

.buttons{

position:absolute;

left:50%;
top:55%;

transform:translateX(-50%);

display:flex;
flex-direction:column;

gap:22px;

width:min(40vw,780px);

}

.buttons a,
.buttons button{

padding:0;
margin:0;
border:none;
background:none;
cursor:pointer;

}

.buttons img{

display:block;
width:100%;
height:auto;

}

@media (max-width:900px){

.buttons{

width:78vw;
top:56%;

}

}

</style>

</head>

<body>

<div class="wrapper">

<img
src="/images/404-1.png"
alt=""
class="bg"
draggable="false"
/>

<div class="buttons">

<a href="https://www.nishikinolab.net">

<img
src="/images/404b1.png"
alt="Respawn"
draggable="false"
/>

</a>

<button
type="button"
onclick="window.close()"
>

<img
src="/images/404b2.png"
alt="Title screen"
draggable="false"
/>

</button>

</div>

</div>

<script is:inline>

const btn=document.querySelector("button");

btn.addEventListener("click",()=>{

window.open("","_self");
window.close();

if(!window.closed){

history.length>1
?history.back()
:location.href="about:blank";

}

});

</script>

</body>

</html>