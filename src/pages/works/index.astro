---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/common/Container.astro";

const works = [
  {
    title: "江戸城",
    category: "城郭",
    image: "/images/edocastle.jpg",
    link: "/works/edocastle/"
  },
  {
    title: "初代 錦乃江戸城",
    category: "城郭",
    image: "/images/nishikino-edo-1.jpg",
    link: "#"
  },
  {
    title: "二代目 錦乃江戸城",
    category: "城郭",
    image: "/images/nishikino-edo-2.jpg",
    link: "#"
  },
  {
    title: "名古屋城天守・本丸御殿",
    category: "城郭",
    image: "/images/nagoya.jpg",
    link: "/works/nagoya/"
  },
  {
    title: "三代目大阪城天守",
    category: "城郭",
    image: "/images/osaka3.jpg",
    link: "/works/osaka3/"
  },
  {
    title: "福山城天守",
    category: "城郭",
    image: "/images/fukuyama.jpg",
    link: "#"
  },
  {
    title: "熊本城天守",
    category: "城郭",
    image: "/images/kumamoto.jpg",
    link: "#"
  },
  {
    title: "川越 蔵造りの町並み",
    category: "和風の町並み",
    image: "/images/kawagoe.jpg",
    link: "#"
  },
  {
    title: "壮厳な神社",
    category: "神社",
    image: "/images/shrine.jpg",
    link: "#"
  },
  {
    title: "王都ファンタジー住宅",
    category: "ファンタジー",
    image: "/images/fantasy-house.jpg",
    link: "#"
  },
  {
    title: "初音ミク",
    category: "キャラクター",
    image: "/images/miku.jpg",
    link: "#"
  }
];
---

<Layout
  title="作品紹介｜WORKS｜錦乃"
  description="城郭を中心に、町並みや神社、武家屋敷、創作作品、図面・建築考証など錦乃の制作作品を紹介しています。"
>

<section class="relative min-h-screen overflow-hidden bg-[#140f0d]">

  <img
    src="/images/works-bg.png"
    alt="作品紹介背景"
    class="absolute inset-0 h-full w-full object-cover select-none pointer-events-none"
    draggable="false"
  />

  <div class="absolute inset-0 bg-black/15"></div>

  <div class="relative z-10 py-32">

    <Container class="works-container">

      <div class="mx-auto max-w-5xl">

        <p class="works-reveal mb-4 tracking-[0.45em] text-sm text-white/80">
          WORKS
        </p>

        <h1
          class="works-reveal text-6xl leading-tight text-white"
          style="font-family:'Cormorant Garamond',serif;"
        >
          作品紹介
        </h1>

      </div>

      <div class="works-grid mt-20">

        {
          works.map((work, index) => (

            <a
              href={work.link}
              class="works-reveal works-card"
              style={`transition-delay:${index * 50}ms;`}
            >

              <div class="works-image-wrap">

                <img
                  src={work.image}
                  alt={work.title}
                  loading="lazy"
                  class="works-image"
                />

              </div>

              <div class="works-body">

                <p class="works-category">
                  {work.category}
                </p>

                <h2
                  class="works-title"
                  style="font-family:'Cormorant Garamond',serif;"
                >
                  {work.title}
                </h2>

              </div>

            </a>

          ))
        }

      </div>

    </Container>

  </div>

</section>

<style>

.works-container{

max-width:1800px;

}

/* ===== Grid ===== */

.works-grid{

display:grid;

grid-template-columns:repeat(5,minmax(0,1fr));

gap:1.35rem;

align-items:start;

}

@media(max-width:1700px){

.works-grid{

grid-template-columns:repeat(4,minmax(0,1fr));

}

}

@media(max-width:1200px){

.works-grid{

grid-template-columns:repeat(3,minmax(0,1fr));

}

}

@media(max-width:760px){

.works-grid{

grid-template-columns:repeat(2,minmax(0,1fr));

gap:.8rem;

}

}

@media(max-width:640px){

.works-container{

padding-left:.8rem;

padding-right:.8rem;

}

}

/* ===== Card ===== */
.works-card{

display:block;
width:100%;
min-width:0;

}

.works-grid{

display:grid !important;

grid-template-columns:repeat(2,1fr) !important;

gap:20px !important;

background:red !important;

}

.works-card{

display:block;

background:rgba(255,255,255,.78);

backdrop-filter:blur(16px);

border:1px solid rgba(255,255,255,.65);

border-radius:1.25rem;

overflow:hidden;

transition:
transform .35s ease,
box-shadow .35s ease;

}

.works-card:hover{

transform:translateY(-8px);

box-shadow:0 18px 40px rgba(0,0,0,.18);

}

.works-image-wrap{

width:100%;

}

.works-body{

width:100%;

}

.works-image{

display:block;

width:100%;

aspect-ratio:1/1;

object-fit:cover;

border-radius:.9rem;

transition:transform .8s cubic-bezier(.22,1,.36,1);

}

.works-card:hover .works-image{

transform:scale(1.05);

}

.works-body{

padding:0 .8rem .9rem;

}

.works-category{

font-size:11px;

letter-spacing:.18em;

color:#6a6a6a;

text-transform:uppercase;

}

.works-title{

margin-top:.3rem;

font-size:1.45rem;

line-height:1.25;

color:#181818;

}

@media(max-width:760px){

.works-card{

border-radius:1rem;

}

.works-image-wrap{

padding:.5rem;

}

.works-image{

border-radius:.7rem;

}

.works-body{

padding:0 .55rem .65rem;

}

.works-category{

font-size:8px;

letter-spacing:.12em;

}

.works-title{

font-size:.95rem;

line-height:1.25;

}

}

/* ===== Reveal ===== */

.works-reveal{

opacity:0;

transform:
translateY(60px)
scale(.96);

transition:
opacity .9s cubic-bezier(.22,1,.36,1),
transform .9s cubic-bezier(.22,1,.36,1);

will-change:
opacity,
transform;

}

.works-show{

animation:
worksBounce .9s cubic-bezier(.22,1,.36,1) forwards;

}

@keyframes worksBounce{

0%{

opacity:0;

transform:
translateY(60px)
scale(.96);

}

65%{

opacity:1;

transform:
translateY(-8px)
scale(1.02);

}

100%{

opacity:1;

transform:
translateY(0)
scale(1);

}

}

</style>

<script>

const observer=new IntersectionObserver((entries)=>{

entries.forEach((entry)=>{

if(!entry.isIntersecting)return;

entry.target.classList.add("works-show");

observer.unobserve(entry.target);

});

},{

threshold:.15,

rootMargin:"0px 0px -10% 0px"

});

document.querySelectorAll(".works-reveal").forEach((el)=>{

observer.observe(el);

});

</script>

</Layout>