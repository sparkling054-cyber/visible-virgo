---
import Layout from "../../layouts/Layout.astro";

const categories = [
  {
    title: "個人",
    subtitle: "Creator",
    text:
      "YouTube・SNS・Minecraft・配信活動・創作活動など、個人クリエイター様との制作やコラボレーション。"
  },
  {
    title: "企業",
    subtitle: "Business",
    text:
      "広告、映像、プロモーション、コンテンツ制作、展示企画など幅広く対応しています。"
  },
  {
    title: "自治体・文化機関",
    subtitle: "Public",
    text:
      "観光、文化財、歴史イベント、地域活性化、日本文化発信などのご相談。"
  },
  {
    title: "監修・資料提供",
    subtitle: "Research",
    text:
      "歴史建築、城郭、町並み、世界観設定などの監修・考証・資料提供。"
  }
];
---

<Layout
  title="CONTACT｜錦乃"
  description="個人・企業・自治体・研究機関・イベントなど幅広いご相談を受け付けています。"
>

<section class="relative h-[820px] overflow-hidden">

  <img
    src="/images/contact-bg.png"
    alt="茶室の背景"
    class="contact-image absolute inset-0 h-full w-full object-cover select-none pointer-events-none"
    draggable="false"
  />

  <div class="absolute inset-0 bg-black/10"></div>

  <div class="absolute bottom-16 right-12 z-20 flex flex-col items-center">

    <div class="h-20 w-px bg-white/70"></div>

    <span class="mt-4 text-xs tracking-[0.45em] text-white">
      SCROLL
    </span>

  </div>

</section>

<section class="bg-[#faf8f3] py-32">

  <div class="mx-auto max-w-7xl px-8">

    <div class="max-w-5xl">

      <p
        class="contact-reveal mb-4 tracking-[0.45em] text-sm text-neutral-500"
      >
        CONTACT
      </p>

      <h1
        class="contact-reveal text-6xl leading-tight text-neutral-900"
        style="font-family:'Cormorant Garamond',serif;"
      >
        茶室へようこそ。
      </h1>

      <p
        class="contact-reveal mt-10 text-lg leading-10 text-neutral-700"
        style="font-family:'Shippori Mincho',serif;"
      >
        「こんなことお願いできますか？」<br><br>

        そんな一言からでも大丈夫です。<br>

        個人のクリエイター様から企業・番組・自治体・都市まで、<br>
        一緒に面白いものを作れる出会いを<br>
        楽しみにしています。
      </p>

    </div>

    <div class="contact-reveal mt-28 mb-16">

      <p
        class="tracking-[0.35em] text-sm text-neutral-500"
      >
        COLLABORATION
      </p>

      <h2
        class="mt-3 text-5xl text-neutral-900"
        style="font-family:'Cormorant Garamond',serif;"
      >
        ご相談いただける内容
      </h2>

      <p
        class="mt-8 max-w-3xl leading-9 text-neutral-700"
      >
        制作内容が決まっていなくても問題ありません。
        「こんなことができたら面白そう」
        という段階から一緒に考えます。
      </p>

    </div>

    <div class="grid gap-8 md:grid-cols-2">

      {
        categories.map((item, index) => (

          <article
            class="contact-reveal rounded-[2rem] border border-white/70 bg-white/70 p-10 backdrop-blur-md transition duration-500 hover:-translate-y-2 hover:shadow-2xl"
            style={`transition-delay:${index * 120}ms;`}
          >

            <p
              class="tracking-[0.35em] text-xs text-rose-400"
            >
              {item.subtitle}
            </p>

            <h3
              class="mt-4 text-3xl text-neutral-900"
              style="font-family:'Cormorant Garamond',serif;"
            >
              {item.title}
            </h3>

            <p
              class="mt-6 leading-8 text-neutral-700"
            >
              {item.text}
            </p>

          </article>

        ))
      }

    </div>

  </div>

</section>

<section class="bg-white py-28">

  <div class="mx-auto max-w-6xl px-8">

    <div class="contact-reveal text-center">

      <p
        class="tracking-[0.35em] text-sm text-neutral-500"
      >
        INVITATION
      </p>

      <h2
        class="mt-4 text-5xl text-neutral-900"
        style="font-family:'Cormorant Garamond',serif;"
      >
        こんなお話を歓迎しています。
      </h2>

      <p
        class="mx-auto mt-8 max-w-3xl leading-9 text-neutral-700"
      >
        小さなアイデアから大きな企画まで。
        「一緒に作ってみたい。」
        そんな気持ちを大切にしています。
      </p>

    </div>

    <div class="mt-20 grid gap-6 md:grid-cols-2 lg:grid-cols-3">

      <div class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8" style="transition-delay:0ms;">
        <h3 class="text-2xl">🎥 YouTube・配信</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          動画企画、配信企画、世界観制作、
          Minecraft建築など。
        </p>
      </div>

      <div class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8" style="transition-delay:120ms;">
        <h3 class="text-2xl">🤝 コラボレーション</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          クリエイター同士の共同制作、
          イベント企画、
          SNSでの発信など。
        </p>
      </div>

      <div class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8" style="transition-delay:240ms;">
        <h3 class="text-2xl">🏯 地域・文化</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          自治体、
          博物館、
          観光、
          歴史文化発信への協力。
        </p>
      </div>

            <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:360ms;"
      >
        <h3 class="text-2xl">📺 メディア</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          テレビ、
          Webメディア、
          雑誌、
          映像制作への出演・制作協力。
        </p>
      </div>

      <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:480ms;"
      >
        <h3 class="text-2xl">📚 監修・資料提供</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          城郭、
          御殿、
          歴史建築、
          世界観設定など。
        </p>
      </div>

      <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:600ms;"
      >
        <h3 class="text-2xl">✨ その他</h3>
        <p class="mt-4 leading-8 text-neutral-700">
          「こんなこと出来ますか？」
          という段階からお気軽にご相談ください。
        </p>
      </div>

    </div>

  </div>

</section>

<section class="bg-[#f7f5ef] py-32">

  <div class="mx-auto max-w-5xl px-8 text-center">

    <div class="contact-reveal">

      <p
        class="tracking-[0.35em] text-sm text-neutral-500"
      >
        MESSAGE
      </p>

      <h2
        class="mt-4 text-5xl text-neutral-900"
        style="font-family:'Cormorant Garamond',serif;"
      >
        一緒に、
        面白い景色を作りませんか。
      </h2>

      <p
        class="mx-auto mt-10 max-w-3xl leading-9 text-neutral-700"
        style="font-family:'Shippori Mincho',serif;"
      >
        歴史でも、
        ゲームでも、
        写真でも、
        映像でも。

        <br><br>

        「こんな景色が見てみたい。」

        <br><br>

        そんな想像から始まる出会いを
        楽しみにしています。
      </p>

    </div>

    <a
  href="/contact/form/"
  class="contact-reveal mt-14 inline-flex h-44 w-44 items-center justify-center rounded-full border border-neutral-900 bg-white text-center text-lg transition duration-500 hover:-translate-y-2 hover:shadow-2xl"
  style="transition-delay:250ms;"
>
  お話を<br>
  聞かせてください。
</a>

  </div>

</section>

<section class="bg-white py-24">

  <div class="mx-auto max-w-5xl px-8">

    <div class="contact-reveal text-center">

      <p
        class="tracking-[0.35em] text-sm text-neutral-500"
      >
        FAQ
      </p>

      <h2
        class="mt-4 text-5xl"
        style="font-family:'Cormorant Garamond',serif;"
      >
        よくあるご相談
      </h2>

    </div>

    <div class="mt-16 space-y-8">

      <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:0ms;"
      >
        <h3 class="text-xl font-semibold">
          企画がまだ固まっていません。
        </h3>

        <p class="mt-4 leading-8 text-neutral-700">
          問題ありません。
          アイデア段階から一緒に考えることも歓迎しています。
        </p>
      </div>

      <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:120ms;"
      >
        <h3 class="text-xl font-semibold">
          個人でも相談できますか？
        </h3>

        <p class="mt-4 leading-8 text-neutral-700">
          もちろんです。
          個人・クリエイター・配信活動者の方からのご相談も歓迎しています。
        </p>
      </div>

      <div
        class="contact-reveal rounded-[2rem] bg-[#faf8f3] p-8"
        style="transition-delay:240ms;"
      >
        <h3 class="text-xl font-semibold">
          相談だけでも大丈夫ですか？
        </h3>

        <p class="mt-4 leading-8 text-neutral-700">
          はい。
          「こんなことができたら面白そう」という段階でもお気軽にご連絡ください。
        </p>
      </div>

    </div>

  </div>

</section>

<style>

.contact-image{
  animation:contactFloat 10s ease-in-out infinite;
  transform-origin:center;
}

@keyframes contactFloat{

0%{
transform:translateY(0) scale(1.02);
}

50%{
transform:translateY(-16px) scale(1.04);
}

100%{
transform:translateY(0) scale(1.02);
}

}

/* ----------------------------- */
/* Scroll Reveal */
/* ----------------------------- */

.contact-reveal{

opacity:0;

transform:
translateY(70px)
scale(.96);

transition:
opacity .9s cubic-bezier(.22,1,.36,1),
transform .9s cubic-bezier(.22,1,.36,1);

will-change:
transform,
opacity;

}

.contact-show{

animation:
contactBounce .9s cubic-bezier(.22,1,.36,1) forwards;

}

@keyframes contactBounce{

0%{

opacity:0;

transform:
translateY(70px)
scale(.96);

}

65%{

opacity:1;

transform:
translateY(-10px)
scale(1.02);

}

100%{

opacity:1;

transform:
translateY(0)
scale(1);

}

}

</style>

<script>

const observer = new IntersectionObserver((entries)=>{

entries.forEach((entry)=>{

if(!entry.isIntersecting) return;

const el = entry.target;

el.classList.add("contact-show");

observer.unobserve(el);

});

},{
threshold:0.18,
rootMargin:"0px 0px -10% 0px"
});

document.querySelectorAll(".contact-reveal").forEach((el)=>{

observer.observe(el);

});

</script>

</Layout>