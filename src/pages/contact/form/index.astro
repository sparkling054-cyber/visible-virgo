---
import Layout from "../../../layouts/Layout.astro";

const categories = [
  "個人・クリエイター",
  "企業・法人",
  "自治体・文化機関",
  "メディア・イベント",
  "研究・資料協力",
  "その他"
];

const purposes = [
  "YouTube・動画制作",
  "SNS・コンテンツ制作",
  "クリエイターコラボレーション",
  "Minecraft・デジタル制作",
  "歴史・城郭・文化関連",
  "監修・資料提供",
  "メディア出演・取材",
  "企業・都市・専門機関・自治体プロジェクト",
  "その他"
];
---

<Layout
  title="お問い合わせ｜錦乃"
  description="錦乃への制作依頼、コラボレーション、歴史文化関連のご相談を受け付けています。"
>

<section
  class="relative h-[650px] overflow-hidden"
>

<img
  alt="お問い合わせ背景"
  class="form-image absolute inset-0 h-full w-full object-cover select-none"
  draggable="false"
/>

<div
  class="absolute inset-0 bg-black/20"
></div>

<div
  class="relative z-10 flex h-full items-center justify-center px-8 text-center text-white"
>

<div
  class="form-reveal"
>

<p
  class="tracking-[0.45em] text-sm"
>
CONTACT FORM
</p>

<h1
  class="mt-6 text-6xl"
  style="font-family:'Cormorant Garamond',serif;"
>
ご相談・お問い合わせ
</h1>

<p
  class="mt-8 leading-9"
  style="font-family:'Shippori Mincho',serif;"
>
「こんなことお願いできますか？」<br><br>

そんな一言からでも大丈夫です。<br>

内容がまだ決まっていなくても、<br>
まずはお気軽にお話を聞かせてください。
</p>

</div>

</div>

</section>

<section
class="bg-[#faf8f3] py-32"
>

<div
class="mx-auto max-w-5xl px-8"
>

<div
class="form-reveal mb-20 text-center"
>

<p
class="tracking-[0.35em] text-sm text-neutral-500"
>
MESSAGE
</p>

<h2
class="mt-5 text-5xl text-neutral-900"
style="font-family:'Cormorant Garamond',serif;"
>
まずはお気軽に。
</h2>

<p
class="mx-auto mt-8 max-w-3xl leading-9 text-neutral-700"
style="font-family:'Shippori Mincho',serif;"
>

制作依頼、企画相談、コラボレーションなど、<br>
内容が決まっていない段階でも歓迎しています。

<br><br>

「こんなことができたら面白そう」<br><br>

そんな想像から、一緒に形にしていければ嬉しいです。

</p>

</div>

<form
action="/api/contact"
method="POST"
class="form-reveal rounded-[2.5rem] border border-white bg-white/80 p-10 shadow-xl backdrop-blur-md md:p-14"
>

<div
class="hidden"
aria-hidden="true"
>

<label>
Leave this field empty
</label>

<input
type="text"
name="website"
/>

</div>

<div
class="grid gap-8"
>

<div>

<label
for="category"
class="block text-sm tracking-widest text-neutral-600"
>
ご相談者様について
</label>

<select
id="category"
name="category"
required
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
>

<option value="">
選択してください
</option>

{
categories.map((category)=>(
<option value={category}>
{category}
</option>
))
}

</select>

</div>

<div>

<label
for="name"
class="block text-sm tracking-widest text-neutral-600"
>
お名前
</label>

<input
id="name"
name="name"
type="text"
required
maxlength="50"
placeholder="お名前または活動名をご入力ください"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
/>

</div>

<div>

<label
for="sns"
class="block text-sm tracking-widest text-neutral-600"
>
SNS・Webサイト（任意）
</label>

<input
id="sns"
name="sns"
type="url"
placeholder="YouTube・X・WebサイトなどのURL"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
/>

</div>

<div>

<label
for="email"
class="block text-sm tracking-widest text-neutral-600"
>
メールアドレス
</label>

<input
id="email"
name="email"
type="email"
required
placeholder="example@example.com"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
/>

</div>

<div>

<label
for="organization"
class="block text-sm tracking-widest text-neutral-600"
>
法人・団体名（任意）
</label>

<input
id="organization"
name="organization"
type="text"
maxlength="100"
placeholder="企業名・団体名などをご入力ください"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
/>

</div>

<!-- Purpose -->

<div>

<label
for="purpose"
class="block text-sm tracking-widest text-neutral-600"
>
ご相談内容
</label>

<select
id="purpose"
name="purpose"
required
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
>

<option value="">
選択してください
</option>

{
purposes.map((purpose)=>(
<option value={purpose}>
{purpose}
</option>
))
}

</select>

</div>

<!-- その他入力（初期は非表示） -->

<div
id="other-purpose-area"
class="hidden"
>

<label
for="otherPurpose"
class="block text-sm tracking-widest text-neutral-600"
>
ご相談内容（自由入力）
</label>

<input
id="otherPurpose"
name="otherPurpose"
type="text"
maxlength="200"
placeholder="ご相談内容をご自由にご入力ください"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 text-neutral-800 outline-none transition focus:border-neutral-800"
/>

</div>

<!-- Message -->

<div>

<label
for="message"
class="block text-sm tracking-widest text-neutral-600"
>
お問い合わせ内容
</label>

<textarea
id="message"
name="message"
required
maxlength="2000"
rows="8"
placeholder="ご相談内容や実現したいことなど、分かる範囲でご記入ください。

内容がまだ決まっていない段階でも大丈夫です。"
class="mt-4 w-full rounded-2xl border border-neutral-200 bg-white px-5 py-4 leading-8 text-neutral-800 outline-none transition focus:border-neutral-800"
></textarea>

<p
class="mt-3 text-xs text-neutral-500"
>
最大2000文字まで入力できます。
</p>

</div>

<!-- Submit -->

<div
class="pt-8 text-center"
>

<button
type="submit"
class="inline-flex h-40 w-40 items-center justify-center rounded-full border border-neutral-900 bg-white text-lg transition duration-500 hover:-translate-y-2 hover:shadow-2xl"
>

送信する

</button>

</div>

</div>

</form>

</div>

</section>

<section
class="bg-white py-24"
>

<div
class="mx-auto max-w-5xl px-8 text-center"
>

<div
class="form-reveal"
>

</div>

<a
href="/contact/"
class="form-reveal mt-16 inline-flex rounded-full border border-neutral-800 px-10 py-4 transition hover:bg-neutral-900 hover:text-white"
>
CONTACTページへ戻る
</a>

</div>

</section>

<style>

.form-image{

animation:
formFloat 12s ease-in-out infinite;

transform-origin:center;

}

@keyframes formFloat{

0%{

transform:
scale(1.03)
translateY(0);

}

50%{

transform:
scale(1.06)
translateY(-18px);

}

100%{

transform:
scale(1.03)
translateY(0);

}

}

.form-reveal{

opacity:0;

transform:
translateY(60px)
scale(.97);

transition:
opacity .9s cubic-bezier(.22,1,.36,1),
transform .9s cubic-bezier(.22,1,.36,1);

}

.form-show{

animation:
formBounce .9s cubic-bezier(.22,1,.36,1)
forwards;

}

@keyframes formBounce{

0%{

opacity:0;

transform:
translateY(60px)
scale(.97);

}

70%{

opacity:1;

transform:
translateY(-8px)
scale(1.02);

}

100%{

opacity:1;

transform:
translateY(0)
scale(1);

}

}

.hidden{

display:none;

}

</style>

<script>

const observer =
new IntersectionObserver(
(entries)=>{

entries.forEach((entry)=>{

if(!entry.isIntersecting)
return;

entry.target.classList.add(
"form-show"
);

observer.unobserve(
entry.target
);

});

},
{

threshold:0.18

}
);

document
.querySelectorAll(".form-reveal")
.forEach((element)=>{

observer.observe(element);

});

const purposeSelect =
document.getElementById("purpose");

const otherArea =
document.getElementById("other-purpose-area");

const otherInput =
document.getElementById("otherPurpose");

function toggleOtherPurpose(){

if(
purposeSelect.value ===
"その他（自由に相談を書く）"
){

otherArea.classList.remove("hidden");

otherInput.required = true;

}else{

otherArea.classList.add("hidden");

otherInput.required = false;

otherInput.value = "";

}

}

toggleOtherPurpose();

purposeSelect.addEventListener(
"change",
toggleOtherPurpose
);

</script>

</Layout>