<style>

.contact-image{
animation:contactFloat 10s ease-in-out infinite;
transform-origin:center;
}



@keyframes contactFloat{

0%{
transform:translateY(0) scale(1.02);
}

50%{
transform:translateY(-16px) scale(1.04);
}

100%{
transform:translateY(0) scale(1.02);
}

}



/* Scroll Reveal */

.contact-reveal{

opacity:0;

transform:
translateY(50px)
scale(.97);

transition:
opacity .9s cubic-bezier(.22,1,.36,1),
transform .9s cubic-bezier(.22,1,.36,1);

will-change:
transform,
opacity;

}



.contact-show{

animation:
contactBounce .9s cubic-bezier(.22,1,.36,1) forwards;

}



@keyframes contactBounce{

0%{
opacity:0;
transform:
translateY(50px)
scale(.97);
}


65%{
opacity:1;
transform:
translateY(-8px)
scale(1.01);
}


100%{
opacity:1;
transform:
translateY(0)
scale(1);
}

}

</style>



<script>

const observer = new IntersectionObserver((entries)=>{

entries.forEach((entry)=>{

if(!entry.isIntersecting) return;

const el = entry.target;

el.classList.add("contact-show");

observer.unobserve(el);

});

},{
threshold:0.18,
rootMargin:"0px 0px -10% 0px"
});



document
.querySelectorAll(".contact-reveal")
.forEach((el)=>{

observer.observe(el);

});

</script>



</Layout>