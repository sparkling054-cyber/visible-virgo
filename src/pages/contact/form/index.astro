---
import Layout from "../../layouts/Layout.astro";

const categories = [
  {
    title: "個人",
    subtitle: "Creator",
    text:
      "YouTube・SNS・Minecraft・配信活動・創作活動など、個人クリエイター様との制作やコラボレーション。"
  },
  {
    title: "企業",
    subtitle: "Business",
    text:
      "広告、映像、プロモーション、コンテンツ制作、展示企画など幅広く対応しています。"
  },
  {
    title: "自治体・文化機関",
    subtitle: "Public",
    text:
      "観光、文化財、歴史イベント、地域活性化、日本文化発信などのご相談。"
  },
  {
    title: "監修・資料提供",
    subtitle: "Research",
    text:
      "歴史建築、城郭、町並み、世界観設定などの監修・考証・資料提供。"
  }
];
---

<Layout
  title="CONTACT｜錦乃"
  description="個人・企業・自治体・研究機関・イベントなど幅広いご相談を受け付けています。"
>


