      class="
        contact-image
        absolute inset-0
        h-full w-full
        object-cover
        select-none
        pointer-events-none
      "
      draggable="false"
    />

  </picture>


  <div class="absolute inset-0 bg-black/10"></div>


  <div
    class="
      absolute
      bottom-8 right-6
      sm:bottom-16 sm:right-12
      z-20
      flex flex-col items-center
