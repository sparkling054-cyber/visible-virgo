<!doctype html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0"
/>

<title>404 Not Found</title>

<style>
html,
body{
  margin:0;
  width:100%;
  height:100%;
  overflow:hidden;
  background:#000;
}

body{
  display:flex;
  justify-content:center;
  align-items:center;
}

.wrapper{
  width:100vw;
  height:100vh;
}

.bg{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  user-select:none;
  pointer-events:none;
}
</style>

</head>

<body>

<div class="wrapper">

<picture>

  <!-- スマホ用 -->
  <source
    media="(max-width:900px)"
    srcset="/images/404-4m.png"
  >

  <!-- PC用 -->
  <img
    src="/images/404-4.png"
    alt=""
    class="bg"
    draggable="false"
  >

</picture>

</div>

</body>
</html>