---
import Container from "../common/Container.astro";
import Section from "../common/Section.astro";
import SectionTitle from "../common/SectionTitle.astro";
import ScrollReveal from "../common/ScrollReveal.astro";

const services = [
  {
    title: "立体空間コンテンツ制作",
    text: "城郭・屋敷・住宅・神社寺院町並みなど数多の歴史的建造物の制作や、文化を活かしたデジタルコンテンツの制作を行えます。"
  },
  {
    title: "映像・写真・SNSコンテンツ",
    text: "YouTube向け紹介動画やSNS向けコンテンツ、世界観づくりまで、皆様の所有物の伝えたい魅力に合わせた映像表現をお手伝いします。"
  },
  {
    title: "クリエイターさん・配信者さんコラボレーション",
    text: "ジャンルや活動内容を問わず、動画・配信・企画など色んな形で皆さんの「一緒にこんな企画しませんか？」を叶えます。"
  },
  {
    title: "企業・自治体・都市とのプロジェクト",
    text: "観光・都市または地域振興・歴史および現代文化・展示企画・教育分野など、小規模から大規模まで空間表現やデジタル制作を活かした様々な案件をご一緒いたします。"
  }
];
---

<ScrollReveal>

<Section>

<Container>

<SectionTitle
  en="COLLABORATION"
  title="ご依頼・コラボレーション"
  description="個人から企業・自治体・文化機関まで、様々な制作や企画のご相談ができます。"
/>

<div class="mt-16 grid gap-8 md:grid-cols-2">

  {
    services.map((service) => (

      <article
        class="group overflow-hidden rounded-[2rem]
        border border-white/60
        bg-gradient-to-br
        from-white/90
        via-rose-50/70
        to-sky-50/70
        p-8
        backdrop-blur-md
        shadow-lg
        transition-all duration-500
        hover:-translate-y-2
        hover:shadow-2xl"
      >

        <p
          class="text-xs tracking-[0.35em] text-neutral-500 uppercase"
        >
          Collaboration
        </p>

        <h3
          class="mt-4 text-2xl text-neutral-900"
          style="font-family:'Cormorant Garamond',serif;"
        >
          {service.title}
        </h3>

        <div
          class="mt-6 h-px w-16 bg-gradient-to-r from-rose-300 via-amber-300 to-sky-300"
        ></div>

        <p
          class="mt-6 leading-8 text-neutral-700"
          style="font-family:'Shippori Mincho',serif;"
        >
          {service.text}
        </p>

      </article>

    ))
  }

</div>

</Container>

</Section>

</ScrollReveal>