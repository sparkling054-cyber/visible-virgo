---
import Container from "../common/Container.astro";
import Section from "../common/Section.astro";
import SectionTitle from "../common/SectionTitle.astro";
import ScrollReveal from "../common/ScrollReveal.astro";


const achievements = [
  {
    title: "建築・空間作品制作",
    text: "Minecraftなどのデジタル空間を活用し、建物や街並みなど様々な空間作品を制作しています。"
  },
  {
    title: "資料調査・空間考証",
    text: "図面や写真、資料などをもとに、建物の構造や空間の成り立ちを調べ、制作へ反映しています。"
  },
  {
    title: "作品発信・メディア掲載",
    text: "制作した作品を動画や写真として発信し、各種メディアなどを通じて紹介されています。"
  },
  {
    title: "世界・設定制作",
    text: "実在するものだけに限らず、想像から生まれる建築や空間、世界観づくりにも取り組んでいます。"
  }
];

---

<ScrollReveal>

<Section>

  <Container>


    <SectionTitle
      en="ACHIEVEMENTS"
      title="実績"
      description="これまでの制作活動・発信活動について"
    />



    <div
      class="mt-16 grid gap-8 md:grid-cols-2"
    >


      {
        achievements.map((item, index) => (

          <div
            class="rounded-3xl bg-white p-8 shadow-lg transition hover:-translate-y-1"
            style={`transition-delay:${index * 150}ms`}
          >


            <p
              class="text-sm tracking-widest text-rose-400"
            >
              0{index + 1}
            </p>



            <h3
              class="mt-4 text-2xl font-bold text-slate-900"
            >
              {item.title}
            </h3>



            <p
              class="mt-4 leading-relaxed text-slate-600"
            >
              {item.text}
            </p>


          </div>

        ))
      }


    </div>


  </Container>

</Section>

</ScrollReveal>