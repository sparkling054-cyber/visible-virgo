<section
  id="hero"
  class="relative min-h-screen overflow-hidden bg-[#140f0d]"
>

  <!-- Hero Image -->
  <picture>
    <!-- Smartphone -->
    <source
      media="(max-width: 639px)"
      srcset="/images/home-mobile.png"
    />

    <!-- PC / Tablet -->
    <img
      src="/images/78adb63e-2db7-4749-bef0-f032743afcde3.png"
      alt="Hero"
      class="absolute inset-0 h-full w-full object-cover select-none pointer-events-none"
      draggable="false"
    />
  </picture>

  <!-- Mobile Image -->
  <img
    src="/images/home-mobile.png"
    alt="Hero Mobile"
    class="absolute inset-0 hidden h-full w-full object-cover select-none pointer-events-none sm:hidden"
    draggable="false"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/10"></div>

</section>