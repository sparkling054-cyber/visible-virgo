---
const menuItems = [
  { name: "HOME", href: "/" },
  { name: "ABOUT", href: "/about/" },
  { name: "WORKS", href: "/works/" },
  { name: "PROFILE", href: "/profile/" },
  { name: "ACHIEVEMENTS", href: "/achievements/" },
  { name: "CONTACT", href: "/contact/" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-[100] transition-all duration-500"
>

<div
class="
mx-auto
flex
max-w-[1800px]
items-center
justify-between

px-4
py-5

sm:px-6
sm:py-7

lg:px-10
lg:py-8
"
>


<!-- Logo -->

<a
href="/"
id="header-logo"
class="flex shrink-0 items-center"
>

<img
src="/images/logo.webp"
alt="錦乃"
draggable="false"

class="
h-11
w-auto

transition
duration-500
hover:scale-105

sm:h-14

lg:h-16
"
/>

</a>



<!-- Navigation -->

<nav
id="header-nav"
class="
ml-auto
mr-2

grid
grid-cols-4
gap-x-2
gap-y-3

opacity-100
transition-all
duration-700
ease-in-out

sm:flex
sm:items-center
sm:gap-5

lg:gap-8
xl:gap-12
"
>

{
menuItems.map((item,index)=>(

<a
href={item.href}

class:list={[
"header-link",

"text-center",

"font-['Cormorant_Garamond']",

"text-[10px]",

"font-medium",

"tracking-[0.05em]",

"text-white",

"transition",

"duration-300",

"hover:text-[#f8dfc1]",

"sm:text-[11px]",
"lg:text-[13px]",
"xl:text-[17px]",

"sm:tracking-[0.16em]",
"xl:tracking-[0.18em]",

index === 4 && "col-start-2",
index === 5 && "col-start-3"
]}
>

{item.name}

</a>

))
}

</nav>

<!-- Menu -->

<button
id="menu-toggle"

type="button"

aria-label="Toggle Navigation"

class="
ml-1

flex

h-10
w-10

shrink-0

items-center
justify-center


sm:ml-4

sm:h-12
sm:w-12
"
>


<div
class="
flex
flex-col

gap-1.5

sm:gap-2
"
>

<span
class="
block
h-px
w-6
bg-white

sm:w-7
"
></span>


<span
class="
block
h-px
w-6
bg-white

sm:w-7
"
></span>


<span
class="
block
h-px
w-6
bg-white

sm:w-7
"
></span>


</div>


</button>


</div>


</header>



<style>

#header-nav{

transition:
opacity .7s ease,
transform .7s ease;

}

.header-hidden{

opacity:0;

pointer-events:none;

transform:
translateX(40px);

}


/* ---------- Mobile ---------- */

@media (max-width:639px){

#header-nav{

width:100%;

grid-template-columns:repeat(4,minmax(0,1fr));

gap:8px 6px;

}

.header-link{

white-space:nowrap;

font-size:10px;

letter-spacing:.02em;

}

}



</style>




<script is:inline>

function initHeader(){


const header =
document.getElementById("site-header");


const nav =
document.getElementById("header-nav");


const toggle =
document.getElementById("menu-toggle");


const logo =
document.getElementById("header-logo");



if(
!header ||
!nav ||
!toggle ||
!logo
)return;



if(toggle.dataset.ready)
return;


toggle.dataset.ready="true";



let menuOpen=false;



toggle.addEventListener(
"click",
()=>{


menuOpen=!menuOpen;



if(menuOpen){


nav.classList.add(
"header-hidden"
);



}
else{


nav.classList.remove(
"header-hidden"
);



}


});





const scrollHandler=()=>{


if(window.scrollY>40){


header.classList.add(
"bg-[#201710]/35",
"backdrop-blur-xl",
"shadow-lg"
);


}
else{


header.classList.remove(
"bg-[#201710]/35",
"backdrop-blur-xl",
"shadow-lg"
);


}


};



scrollHandler();



window.addEventListener(
"scroll",
scrollHandler,
{
passive:true
}
);



}



initHeader();



document.addEventListener(
"astro:page-load",
initHeader
);



</script>