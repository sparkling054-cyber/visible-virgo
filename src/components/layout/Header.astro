---
const menuItems = [
  { name: "HOME", href: "/" },
  { name: "ABOUT", href: "/about/" },
  { name: "WORKS", href: "/works/" },
  { name: "PROFILE", href: "/profile/" },
  { name: "ACHIEVEMENTS", href: "/achievements/" },
  { name: "CONTACT", href: "/contact/" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-[100] transition-all duration-500"
>

  <div
    class="mx-auto flex max-w-[1800px] items-center justify-between 
           px-3 py-4
           sm:px-4 sm:py-5
           lg:px-10 lg:py-8"
  >

    <!-- Logo -->

    <a
      href="/"
      class="flex shrink-0 items-center"
    >

      <img
        src="/images/logo.webp"
        alt="錦乃"
        draggable="false"
        class="
          h-8 w-auto
          sm:h-10
          lg:h-16
          transition duration-500 hover:scale-105
        "
      />

    </a>


    <!-- Navigation -->

    <nav
      id="header-nav"
      class="
        ml-auto
        flex items-center
        gap-2
        sm:gap-3
        lg:gap-8
        xl:gap-12
        transition-all duration-700 ease-in-out
      "
    >

      {
        menuItems.map((item) => (

          <a
            href={item.href}
            class="
              header-link
              font-['Cormorant_Garamond']
              text-[7px]
              sm:text-[9px]
              lg:text-[13px]
              xl:text-[17px]
              font-medium
              tracking-[0.08em]
              sm:tracking-[0.1em]
              lg:tracking-[0.16em]
              xl:tracking-[0.18em]
              text-white
              transition duration-300
              hover:text-[#f8dfc1]
              whitespace-nowrap
            "
          >
            {item.name}
          </a>

        ))
      }

    </nav>


    <!-- Menu -->

    <button
      id="menu-toggle"
      type="button"
      aria-label="Toggle Navigation"
      class="
        ml-2
        sm:ml-4
        flex
        h-8 w-8
        sm:h-10 sm:w-10
        lg:h-12 lg:w-12
        items-center justify-center
      "
    >

      <div class="flex flex-col gap-1.5 sm:gap-2">

        <span class="block h-px w-5 sm:w-6 lg:w-7 bg-white"></span>
        <span class="block h-px w-5 sm:w-6 lg:w-7 bg-white"></span>
        <span class="block h-px w-5 sm:w-6 lg:w-7 bg-white"></span>

      </div>

    </button>

  </div>

</header>


<script is:inline>

function initHeader() {

  const header = document.getElementById("site-header");
  const nav = document.getElementById("header-nav");
  const toggle = document.getElementById("menu-toggle");

  if (!header || !nav || !toggle) return;

  if (toggle.dataset.ready) return;
  toggle.dataset.ready = "true";


  toggle.addEventListener("click", () => {

    nav.classList.toggle("opacity-0");
    nav.classList.toggle("pointer-events-none");

  });


  const scrollHandler = () => {

    if (window.scrollY > 40) {

      header.classList.add(
        "bg-[#201710]/35",
        "backdrop-blur-xl",
        "shadow-lg"
      );

    } else {

      header.classList.remove(
        "bg-[#201710]/35",
        "backdrop-blur-xl",
        "shadow-lg"
      );

    }

  };


  scrollHandler();

  window.addEventListener("scroll", scrollHandler, {
    passive: true
  });

}


initHeader();

document.addEventListener("astro:page-load", initHeader);

</script>