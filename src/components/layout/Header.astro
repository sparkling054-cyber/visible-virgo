---
const menuItems = [
  { name: "HOME", href: "/" },
  { name: "ABOUT", href: "/about/" },
  { name: "WORKS", href: "/works/" },
  { name: "PROFILE", href: "/profile/" },
  { name: "ACHIEVEMENTS", href: "/achievements/" },
  { name: "CONTACT", href: "/contact/" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-[100] transition-all duration-500"
>

  <div
    class="
      mx-auto
      flex
      max-w-[1800px]
      items-center
      justify-between
      px-3
      py-4
      sm:px-6
      sm:py-7
      lg:px-10
      lg:py-8
    "
  >

    <!-- Logo -->
    <a
      href="/"
      id="header-logo"
      class="
        flex
        shrink-0
        items-center
      "
    >

      <img
        src="/images/logo.webp"
        alt="錦乃"
        draggable="false"
        class="
          h-10
          w-auto
          transition
          duration-500
          hover:scale-105

          sm:h-14
          lg:h-16
        "
      />

    </a>



    <!-- PC Navigation -->
    <nav
      id="desktop-nav"
      class="
        hidden

        ml-auto
        items-center

        font-['Cormorant_Garamond']

        text-white

        transition-all
        duration-700

        sm:flex

        gap-5

        lg:gap-8

        xl:gap-12
      "
    >

      {
        menuItems.map((item)=>(
          <a
            href={item.href}
            class="
              header-link

              whitespace-nowrap

              text-[14px]

              tracking-[0.16em]

              transition
              duration-300

              hover:text-[#f8dfc1]

              lg:text-[13px]

              xl:text-[17px]

              xl:tracking-[0.18em]
            "
          >
            {item.name}
          </a>
        ))
      }

    </nav>



    <!-- Smartphone Navigation -->
    <nav
      id="mobile-nav"
      class="
        grid

        grid-cols-3

        gap-y-3

        text-center

        font-['Cormorant_Garamond']

        text-white

        transition-all
        duration-700

        sm:hidden
      "
    >

      <a
        href="/"
        class="mobile-link"
      >
        HOME
      </a>


      <a
        href="/about/"
        class="mobile-link"
      >
        ABOUT
      </a>


      <a
        href="/achievements/"
        class="mobile-link"
      >
        ACHIEVEMENTS
      </a>


      <a
        href="/works/"
        class="mobile-link"
      >
        WORKS
      </a>


      <a
        href="/profile/"
        class="mobile-link"
      >
        PROFILE
      </a>


      <a
        href="/contact/"
        class="mobile-link"
      >
        CONTACT
      </a>


    </nav>




    <!-- Menu -->
    <button
      id="menu-toggle"
      type="button"
      aria-label="Toggle Navigation"
      class="
        ml-2

        flex

        h-9
        w-9

        shrink-0

        items-center
        justify-center

        sm:ml-4

        sm:h-12
        sm:w-12
      "
    >

      <div
        class="
          flex
          flex-col
          gap-1.5

          sm:gap-2
        "
      >

        <span
          class="
            block
            h-px
            w-5
            bg-white

            sm:w-7
          "
        ></span>


        <span
          class="
            block
            h-px
            w-5
            bg-white

            sm:w-7
          "
        ></span>


        <span
          class="
            block
            h-px
            w-5
            bg-white

            sm:w-7
          "
        ></span>

      </div>

    </button>


  </div>

</header>



<style>

#desktop-nav,
#mobile-nav{

  transition:
    opacity .7s ease,
    transform .7s ease;

}


.header-hidden{

  opacity:0;

  pointer-events:none;

  transform:translateX(40px);

}



.mobile-link{

  white-space:nowrap;

  font-size:13px;

  letter-spacing:.04em;

  transition:.3s;

}



.mobile-link:hover{

  color:#f8dfc1;

}



@media(max-width:639px){


  #site-header > div{

    gap:8px;

  }


  #mobile-nav{

    flex:1;

  }


}



</style>



<script is:inline>

function initHeader(){

  const header =
    document.getElementById("site-header");


  const desktop =
    document.getElementById("desktop-nav");


  const mobile =
    document.getElementById("mobile-nav");


  const toggle =
    document.getElementById("menu-toggle");



  if(
    !header ||
    !desktop ||
    !mobile ||
    !toggle
  ) return;



  if(toggle.dataset.ready)
    return;


  toggle.dataset.ready="true";



  let menuOpen=false;



  toggle.addEventListener(
    "click",
    ()=>{


      menuOpen=!menuOpen;



      if(menuOpen){

        desktop.classList.add(
          "header-hidden"
        );


        mobile.classList.add(
          "header-hidden"
        );


      }else{


        desktop.classList.remove(
          "header-hidden"
        );


        mobile.classList.remove(
          "header-hidden"
        );


      }


    }
  );




  const scrollHandler=()=>{


    if(window.scrollY>40){


      header.classList.add(
        "bg-[#201710]/35",
        "backdrop-blur-xl",
        "shadow-lg"
      );


    }else{


      header.classList.remove(
        "bg-[#201710]/35",
        "backdrop-blur-xl",
        "shadow-lg"
      );


    }


  };



  scrollHandler();



  window.addEventListener(
    "scroll",
    scrollHandler,
    {
      passive:true
    }
  );


}



initHeader();


document.addEventListener(
  "astro:page-load",
  initHeader
);


</script>